<mxCell id="c19" value="Проблема: сканы документов&lt;br&gt;на общем диске доступны&lt;br&gt;всем по доменной учетке.&lt;br&gt;Рекомендация: обезличивание&lt;br&gt;имени файла + шифрование&lt;br&gt;папки + аудит доступа" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=2;dashed=1;arcSize=20;" vertex="1" parent="1"><mxGeometry x="900" y="220" width="230" height="90" as="geometry"/></mxCell>
