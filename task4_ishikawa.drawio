        </mxCell>

        <mxCell id="box_process" value="Процессы&#10;- двойной учёт платежей в Excel и 1С&#10;- нет регламента работы с конфиденциальными данными&#10;- нет процедуры удаления данных по запросу клиента" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=middle;spacing=8;fontSize=11;" vertex="1" parent="1">
