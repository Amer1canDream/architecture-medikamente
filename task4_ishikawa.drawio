        </mxCell>

        <mxCell id="box_reg" value="Регуляторика&#10;- несоответствие требованиям 152-ФЗ&#10;- нет аудита доступа к данным&#10;- риски штрафов и репутационных потерь" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=middle;spacing=8;fontSize=11;" vertex="1" parent="1">
